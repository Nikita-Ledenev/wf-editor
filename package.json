{
  "name": "wf-editor",
  "version": "1.0.0",
  "private": true,
  "description": "Редактор схемы рабочего процесса: таблица (Vue3) + диаграмма (React19), собранные через single-spa",
  "workspaces": [
    "packages/shared",
    "packages/table-vue",
    "packages/diagram-react",
    "packages/root-config"
  ],
  "scripts": {
    "backend": "npm --prefix backend run dev",
    "table": "npm --workspace @wf/table-vue run dev",
    "diagram": "npm --workspace @wf/diagram-react run dev",
    "root": "npm --workspace @wf/root-config run dev",
    "dev": "concurrently -n backend,table,diagram,root -c yellow,green,cyan,magenta \"npm run backend\" \"npm run table\" \"npm run diagram\" \"npm run root\"",
    "test:unit": "npm --workspace @wf/table-vue run test:unit && npm --workspace @wf/diagram-react run test:unit",
    "e2e": "npm --workspace @wf/root-config run e2e",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "stylelint": "stylelint \"packages/**/*.{scss,vue}\"",
    "stylelint:fix": "stylelint \"packages/**/*.{scss,vue}\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{scss,css}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.4",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^14.0.0",
    "typescript-eslint": "^8.61.1",
    "vue-eslint-parser": "^10.4.1"
  }
}
